<UserControl x:Class="LoneEftDmaRadar.UI.Radar.Views.SettingsTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LoneEftDmaRadar.UI.Radar.Views"
             xmlns:vm="clr-namespace:LoneEftDmaRadar.UI.Radar.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Padding="10">

    <d:UserControl.DataContext>
        <d:DesignInstance Type="{x:Type vm:SettingsViewModel}"
                          IsDesignTimeCreatable="False" />
    </d:UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Orientation="Vertical"
                    Margin="0,0,0,10">

            <!-- Quick Actions -->
            <WrapPanel Margin="0,0,0,12">
                <Button Content="Restart Radar"
                        ToolTip="Restarts the Radar for the current raid instance. Zoom: F1/F2 | Fullscreen: F11"
                        Command="{Binding RestartRadarCommand}"
                        MinWidth="100"
                        Height="35"
                        Margin="0,0,8,8" />
                <Button Content="Color Picker"
                        ToolTip="Allows customizing entity colors on the Radar UI."
                        IsEnabled="{Binding ColorPickerIsEnabled}"
                        Command="{Binding OpenColorPickerCommand}"
                        MinWidth="100"
                        Height="35"
                        Margin="0,0,8,8" />
                <Button Content="Refresh Data"
                        ToolTip="Force refresh item/quest data from tarkov.dev API. Use if quest tracking shows 0 tasks."
                        Command="{Binding RefreshDataCommand}"
                        MinWidth="100"
                        Height="35"
                        Margin="0,0,8,8" />
            </WrapPanel>

            <!-- Config Profiles -->
            <GroupBox Header="Configuration"
                      Margin="0,0,0,8">
                <StackPanel Margin="4">
                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Profile:"
                                   VerticalAlignment="Center"
                                   Width="50" />
                        <ComboBox ItemsSource="{Binding ProfileList}"
                                  SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                  Margin="4,0,0,0"
                                  Width="160"
                                  HorizontalAlignment="Left" />
                    </DockPanel>
                    <WrapPanel Margin="0,0,0,4">
                        <Button Content="Load"
                                ToolTip="Load the selected profile."
                                Command="{Binding LoadProfileCommand}"
                                Padding="10,3"
                                Margin="0,0,6,4" />
                        <Button Content="Save"
                                ToolTip="Save current settings to the selected profile."
                                Command="{Binding SaveProfileCommand}"
                                Padding="10,3"
                                Margin="0,0,6,4" />
                        <Button Content="Save As..."
                                ToolTip="Save current settings as a new profile."
                                Command="{Binding SaveAsProfileCommand}"
                                Padding="10,3"
                                Margin="0,0,6,4" />
                        <Button Content="Delete"
                                ToolTip="Delete the selected profile."
                                Command="{Binding DeleteProfileCommand}"
                                Padding="10,3"
                                Margin="0,0,6,4" />
                        <Button Content="Open Folder"
                                ToolTip="Opens the config folder."
                                Command="{Binding OpenConfigCommand}"
                                Padding="10,3"
                                Margin="0,0,6,4" />
                        <Button Content="Backup"
                                ToolTip="Backs up your current configuration."
                                Command="{Binding BackupConfigCommand}"
                                Padding="10,3"
                                Margin="0,0,6,4" />
                    </WrapPanel>
                    <TextBlock Text="{Binding ActiveProfileLabel}"
                               FontSize="10"
                               Foreground="{DynamicResource App.TextTertiaryBrush}"
                               Margin="0,2,0,0" />
                </StackPanel>
            </GroupBox>

            <!-- Display card -->
            <GroupBox Header="Display"
                      Margin="0,0,0,8">
                <StackPanel>
                    <WrapPanel Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,16,8">
                            <TextBlock Text="UI Scale"
                                       VerticalAlignment="Center"
                                       ToolTip="Sets the scaling factor for the Radar/User Interface. For high‑resolution monitors you may want to increase this." />
                            <Slider x:Name="UIScaleSlider"
                                    Width="150"
                                    Margin="8,0"
                                    Minimum="0.5"
                                    Maximum="2.0"
                                    SmallChange="0.01"
                                    LargeChange="0.1"
                                    Value="{Binding UIScale, Mode=TwoWay}" />
                            <TextBlock Text="{Binding Value, ElementName=UIScaleSlider, StringFormat=F2}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,16,8">
                            <TextBlock Text="Radar Max FPS (0 = Unlimited)"
                                       VerticalAlignment="Center" />
                            <Slider x:Name="RadarFpsSlider"
                                    Width="180"
                                    Margin="8,0"
                                    Minimum="0"
                                    Maximum="240"
                                    SmallChange="5"
                                    LargeChange="15"
                                    TickFrequency="15"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding RadarMaxFPS, Mode=TwoWay}" />
                            <TextBlock Text="{Binding Value, ElementName=RadarFpsSlider, StringFormat='{}{0:F0}'}"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0" />
                        </StackPanel>
                    </WrapPanel>

                    <WrapPanel>
                        <CheckBox Content="Show Map Setup Helper"
                                  ToolTip="Toggles the 'Map Setup Helper' to assist with getting Map Bounds/Scaling"
                                  IsChecked="{Binding ShowMapSetupHelper, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Aimview Widget"
                                  ToolTip="Toggles the Aimview 'Widget' that gives you a Pseudo ESP in the radar window. Can be moved."
                                  IsChecked="{Binding AimviewWidget, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Player Info Widget"
                                  ToolTip="Toggles the Player Info 'Widget' that gives you information about the players/bosses in your raid. Can be moved."
                                  IsChecked="{Binding PlayerInfoWidget, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Connect Groups"
                                  ToolTip="Connects players that are grouped up via semi‑transparent green lines. Does not apply to your own party."
                                  IsChecked="{Binding ConnectGroups, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Auto Groups"
                                  ToolTip="Automatically detects player groups during pre‑raid countdown based on spawn proximity. Also detects teammates."
                                  IsChecked="{Binding AutoGroups, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Hide Names"
                                  ToolTip="Hides human player names from displaying in the Radar or Player Info Widget. Instead will show the (Height,Distance)."
                                  IsChecked="{Binding HideNames, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Show Mines"
                                  IsChecked="{Binding ShowMines, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Teammate Aimlines"
                                  ToolTip="When enabled makes teammate aimlines the same length as the main player."
                                  IsChecked="{Binding TeammateAimlines, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="AI Aimlines"
                                  ToolTip="Enables dynamic aimlines for AI Players. When you are being aimed at the aimlines will extend."
                                  IsChecked="{Binding AIAimlines, Mode=TwoWay}"
                                  Margin="0,0,0,8" />
                        <CheckBox Content="Mark Sus Players"
                                  ToolTip="Marks players as suspicious based on certain criteria (K/D, S/R, etc.)"
                                  IsChecked="{Binding MarkSusPlayers, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Show Doors"
                                  ToolTip="Shows doors on the radar map with lock state indicators."
                                  IsChecked="{Binding ShowDoors, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Key Doors Only"
                                  ToolTip="Only show doors that require a key to unlock. Applies to both radar and ESP."
                                  IsChecked="{Binding KeyDoorsOnly, Mode=TwoWay}"
                                  IsEnabled="{Binding ShowDoors}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Locked Doors"
                                  ToolTip="Show locked doors (red X markers)."
                                  IsChecked="{Binding ShowLockedDoors, Mode=TwoWay}"
                                  IsEnabled="{Binding ShowDoors}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Unlocked Doors"
                                  ToolTip="Show unlocked/open doors (yellow/green X markers)."
                                  IsChecked="{Binding ShowUnlockedDoors, Mode=TwoWay}"
                                  IsEnabled="{Binding ShowDoors}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Show Switches"
                                  ToolTip="Shows power switches on the radar map (cyan diamond markers)."
                                  IsChecked="{Binding ShowSwitches, Mode=TwoWay}"
                                  Margin="0,0,16,8" />
                        <CheckBox Content="Show Card Readers"
                                  ToolTip="Shows card readers on the radar map (magenta square markers)."
                                  IsChecked="{Binding ShowCardReaders, Mode=TwoWay}"
                                  Margin="0,0,0,8" />
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,8,0,0">
                        <TextBlock Text="Widget Font Size"
                                   VerticalAlignment="Center"
                                   ToolTip="Font size for loot height indicators and other radar widgets." />
                        <Slider x:Name="WidgetFontSizeSlider"
                                Width="150"
                                Margin="8,0"
                                Minimum="6"
                                Maximum="24"
                                SmallChange="1"
                                LargeChange="2"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding RadarWidgetFontSize, Mode=TwoWay}" />
                        <TextBlock Text="{Binding Value, ElementName=WidgetFontSizeSlider, StringFormat='{}{0:F0} px'}"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>


        </StackPanel>
    </ScrollViewer>
</UserControl>
